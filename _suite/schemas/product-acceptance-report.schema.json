{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/fstubner/agent-skills/schemas/product-acceptance-report.json",
  "title": "ProductAcceptanceReport",
  "type": "object",
  "required": [
    "generatedBy",
    "generatedAt",
    "root",
    "verdict",
    "blockers",
    "warnings",
    "notes",
    "checks",
    "acceptorContext"
  ],
  "properties": {
    "generatedBy": { "const": "accept-check.js" },
    "generatedAt": { "type": "string" },
    "root": { "type": "string" },
    "suiteProfile": { "type": "object" },
    "acceptorContext": { "type": "string", "enum": ["separate", "same", "unknown"] },
    "productContract": { "type": ["string", "null"] },
    "verdict": { "type": "string", "enum": ["SHIP", "CONDITIONAL", "BLOCK"] },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "message"],
        "properties": {
          "id": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "message"],
        "properties": {
          "id": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "message"],
        "properties": {
          "id": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "not_evaluated"] }
        },
        "additionalProperties": true
      }
    },
    "agentPrompts": { "type": "array", "items": { "type": "string" } },
    "layerNote": { "type": "string" }
  },
  "additionalProperties": true
}
